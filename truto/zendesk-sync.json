{
  "id": "091a1ab9-cf2c-4c96-a427-532793df7f9a",
  "integration_name": "zendesk-help",
  "args_schema": {
    "integrated_account_id": {
      "type": "string",
      "format": "integrated_account_id",
      "required": true
    },
    "webhook_id": {
      "type": "string",
      "format": "webhook_id"
    },
    "google_cloud_storage_datastore_id": {
      "type": "string",
      "format": "datastore_id"
    },
    "team_id": {
      "type": "string",
      "required": true
    },
    "bot_id": {
      "type": "string",
      "required": true
    },
    "source_id": {
      "type": "string",
      "required": true
    }
  },
  "resources": [
    {
      "type": "request",
      "name": "list-pages-filtered",
      "resource": "knowledge-base/pages",
      "method": "list",
      "query": {
        "page_type": "articles",
        "collection": {
          "id": "{{section.value}}",
          "type": "section"
        }
      },
      "integrated_account_id": "{{args.integrated_account_id}}",
      "loop_on": "section",
      "run_if": "$exists(section)"
    },
    {
      "type": "request",
      "name": "list-pages-unfiltered",
      "resource": "knowledge-base/pages",
      "method": "list",
      "query": {
        "page_type": "articles"
      },
      "integrated_account_id": "{{args.integrated_account_id}}",
      "run_if": "$not($exists(section))"
    },
    {
      "type": "add_context",
      "name": "add-page-name-filtered",
      "depends_on": "list-pages-filtered",
      "config": {
        "expression": "{ \"page_id\": resources.`knowledge-base`.pages.id, \"page_title\": resources.`knowledge-base`.pages.title ? resources.`knowledge-base`.pages.title : \"Untitled_\" & resources.`knowledge-base`.pages.id, \"page_url\": resources.`knowledge-base`.pages.urls[type=\"view\"].url }"
      }
    },
    {
      "type": "add_context",
      "name": "add-page-name-unfiltered",
      "depends_on": "list-pages-unfiltered",
      "config": {
        "expression": "{ \"page_id\": resources.`knowledge-base`.pages.id, \"page_title\": resources.`knowledge-base`.pages.title ? resources.`knowledge-base`.pages.title : \"Untitled_\" & resources.`knowledge-base`.pages.id, \"page_url\": resources.`knowledge-base`.pages.urls[type=\"view\"].url }"
      }
    },
    {
      "type": "request",
      "name": "get-page-content-filtered",
      "resource": "knowledge-base/page-content",
      "method": "list",
      "depends_on": "list-pages-filtered",
      "query": {
        "page_type": "{{resources.knowledge-base.pages.page_type}}",
        "page": "{{resources.knowledge-base.pages.id}}",
        "format": "markdown"
      },
      "integrated_account_id": "{{args.integrated_account_id}}",
      "run_if": "resources.`knowledge-base`.pages.status = \"published\""
    },
    {
      "type": "request",
      "name": "get-page-content-unfiltered",
      "resource": "knowledge-base/page-content",
      "method": "list",
      "depends_on": "list-pages-unfiltered",
      "query": {
        "page_type": "{{resources.knowledge-base.pages.page_type}}",
        "page": "{{resources.knowledge-base.pages.id}}",
        "format": "markdown"
      },
      "integrated_account_id": "{{args.integrated_account_id}}",
      "run_if": "resources.`knowledge-base`.pages.status = \"published\""
    },
    {
      "name": "remove-remote-data-filtered",
      "type": "transform",
      "config": {
        "expression": "resources.`knowledge-base`.`page-content`.$sift(function($v, $k) { $k != remote_data })"
      },
      "depends_on": "get-page-content-filtered"
    },
    {
      "name": "remove-remote-data-unfiltered",
      "type": "transform",
      "config": {
        "expression": "resources.`knowledge-base`.`page-content`.$sift(function($v, $k) { $k != remote_data })"
      },
      "depends_on": "get-page-content-unfiltered"
    },
    {
      "name": "all-page-content-filtered",
      "type": "spool",
      "depends_on": "remove-remote-data-filtered"
    },
    {
      "name": "all-page-content-unfiltered",
      "type": "spool",
      "depends_on": "remove-remote-data-unfiltered"
    },
    {
      "name": "combine-page-content-filtered",
      "type": "transform",
      "config": {
        "expression": "{ \"file_id\": page_id, \"file_name\": page_title, \"file_url\": page_url, \"content\": $reduce($sortNodes(resources.`knowledge-base`.`page-content`, \"id\", \"parent.id\"), function($acc, $v) { $acc & ($v.body.format = \"markdown\" ? $v.body.content : \"\") }, \"\" ) }"
      },
      "depends_on": "all-page-content-filtered"
    },
    {
      "name": "combine-page-content-unfiltered",
      "type": "transform",
      "config": {
        "expression": "{ \"file_id\": page_id, \"file_name\": page_title, \"file_url\": page_url, \"content\": $reduce($sortNodes(resources.`knowledge-base`.`page-content`, \"id\", \"parent.id\"), function($acc, $v) { $acc & ($v.body.format = \"markdown\" ? $v.body.content : \"\") }, \"\" ) }"
      },
      "depends_on": "all-page-content-unfiltered"
    },
    {
      "name": "google-cloud-storage-filtered",
      "type": "destination",
      "destination_type": "datastore",
      "method": "uploadObject",
      "depends_on": "combine-page-content-filtered",
      "config": {
        "id": "{{args.google_cloud_storage_datastore_id}}",
        "config": {
          "path": "teams/{{args.team_id}}/bots/{{args.bot_id}}/sources/{{args.source_id}}",
          "file_name": "{{page_title}}.md",
          "content": "{{payload.records.0.content}}",
          "upload_type": "resumable",
          "headers": {
            "Content-Type": "text/markdown",
            "X-Goog-Meta-File-Id": "{{page_id}}",
            "X-Goog-Meta-File-Url": "{{page_url}}"
          }
        }
      },
      "run_if": "$exists(args.google_cloud_storage_datastore_id)",
      "resources_to_persist": [
        "combine-page-content-filtered"
      ]
    },
    {
      "name": "google-cloud-storage-unfiltered",
      "type": "destination",
      "destination_type": "datastore",
      "method": "uploadObject",
      "depends_on": "combine-page-content-unfiltered",
      "config": {
        "id": "{{args.google_cloud_storage_datastore_id}}",
        "config": {
          "path": "teams/{{args.team_id}}/bots/{{args.bot_id}}/sources/{{args.source_id}}",
          "file_name": "{{page_title}}.md",
          "content": "{{payload.records.0.content}}",
          "upload_type": "resumable",
          "headers": {
            "Content-Type": "text/markdown",
            "X-Goog-Meta-File-Id": "{{page_id}}",
            "X-Goog-Meta-File-Url": "{{page_url}}"
          }
        }
      },
      "run_if": "$exists(args.google_cloud_storage_datastore_id)",
      "resources_to_persist": [
        "combine-page-content-unfiltered"
      ]
    }
  ],
  "environment_id": "5e6c1566-bd23-4b05-a481-f579eec913b7",
  "created_at": "2025-02-07T20:39:06.000Z",
  "updated_at": "2025-02-12T10:31:58.000Z",
  "default_runtime_version": 4,
  "label": "Fetch all the pages from Zendesk Help Center",
  "args_validation": "$firstNonEmpty(args.webhook_id, args.google_cloud_storage_datastore_id) ? null : { \"message\": \"Need one of webhook_id or google_cloud_storage_datastore_id in args\" }"
}
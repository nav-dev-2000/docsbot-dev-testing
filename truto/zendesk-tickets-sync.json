{
  "id": "a14eecd6-b3bd-4c5c-9e59-75c1a2e752cf",
  "integration_name": "zendesk-tickets",
  "args_schema": {
    "integrated_account_id": {
      "type": "string",
      "format": "integrated_account_id",
      "required": true
    },
    "webhook_id": {
      "type": "string",
      "format": "webhook_id"
    },
    "google_cloud_storage_datastore_id": {
      "type": "string",
      "format": "datastore_id"
    },
    "team_id": {
      "type": "string",
      "required": true
    },
    "bot_id": {
      "type": "string",
      "required": true
    },
    "source_id": {
      "type": "string",
      "required": true
    },
    "start_date": {
      "type": "string",
      "required": true
    },
    "base_url": {
      "type": "string",
      "required": true
    }
  },
  "resources": [
    {
      "type": "request",
      "name": "list-tickets",
      "resource": "ticketing/tickets",
      "method": "list",
      "query": {
        "status": "closed",
        "created_at": { "gt": "{{args.start_date}}" }
      },
      "integrated_account_id": "{{args.integrated_account_id}}"
    },
    {
      "type": "add_context",
      "name": "add-ticket-context",
      "depends_on": "list-tickets",
      "config": {
        "expression": "{ \"ticket_id\": resources.`ticketing`.tickets.id, \"subject\": resources.`ticketing`.tickets.name, \"ticket_url\": args.base_url & resources.`ticketing`.tickets.id, \"created_by\": resources.`ticketing`.tickets.contact.id }"
      }
    },
    {
      "type": "request",
      "name": "get-ticket-comments",
      "resource": "ticketing/comments",
      "method": "list",
      "depends_on": "list-tickets",
      "query": {
        "ticket_id": "{{resources.ticketing.tickets.id}}"
      },
      "integrated_account_id": "{{args.integrated_account_id}}"
    },
    {
      "name": "combine-ticket-comments",
      "type": "transform",
      "config": {
        "expression": "{ \"file_id\": ticket_id, \"file_name\": subject, \"file_url\": ticket_url, \"content\": $reduce($sort(resources.`ticketing`.comments, function($l, $r) { $l.created_at > $r.created_at }), function($acc, $v) { ($v.is_private = false) ? $acc & ($v.author.id = created_by ? \"<h2>Customer Message</h2>\n\" : \"<h2>Staff Response</h2>\n\") & $v.html_body & \"\n\n---------\n\n\" : $acc }, \"\" ) }"
      },
      "depends_on": "get-ticket-comments"
    },
    {
      "name": "webhook",
      "type": "destination",
      "destination_type": "webhook",
      "config": {
        "id": "{{args.webhook_id}}"
      },
      "run_if": "$exists(args.webhook_id)",
      "resources_to_persist": [
        "combine-ticket-comments"
      ]
    },
    {
      "name": "google-cloud-storage",
      "type": "destination",
      "destination_type": "datastore",
      "method": "uploadObject",
      "config": {
        "id": "{{args.google_cloud_storage_datastore_id}}",
        "config": {
          "path": "teams/{{args.team_id}}/bots/{{args.bot_id}}/sources/{{args.source_id}}",
          "file_name": "{{subject}}_{{ticket_id}}.html",
          "content": "{{payload.records.0.content}}",
          "upload_type": "resumable",
          "headers": {
            "Content-Type": "text/html",
            "X-Goog-Meta-File-Id": "{{ticket_id}}",
            "X-Goog-Meta-File-Url": "{{ticket_url}}",
            "X-Goog-Meta-File-Title": "{{subject}}"
          }
        }
      },
      "run_if": "$exists(args.google_cloud_storage_datastore_id)",
      "resources_to_persist": [
        "combine-ticket-comments"
      ]
    }
  ],
  "environment_id": "5e6c1566-bd23-4b05-a481-f579eec913b7",
  "created_at": "2025-02-21T06:17:11.000Z",
  "updated_at": "2025-02-21T06:17:11.000Z",
  "default_runtime_version": 4,
  "label": "Fetch all the tickets from Zendesk",
  "args_validation": "$firstNonEmpty(args.webhook_id) ? null : { \"message\": \"Need one of webhook_id or google_cloud_storage_datastore_id in args\" }"
}
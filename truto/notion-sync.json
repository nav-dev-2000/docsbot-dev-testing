{
  "id": "a7a0f395-758c-443c-a8eb-365fe7ffde25",
  "integration_name": "notion",
  "args_schema": {
    "integrated_account_id": {
      "type": "string",
      "format": "integrated_account_id",
      "required": true
    },
    "webhook_id": {
      "type": "string",
      "format": "webhook_id"
    },
    "google_cloud_storage_datastore_id": {
      "type": "string",
      "format": "datastore_id"
    },
    "team_id": {
      "type": "string",
      "required": true
    },
    "bot_id": {
      "type": "string",
      "required": true
    },
    "source_id": {
      "type": "string",
      "required": true
    }
  },
  "resources": [
    {
      "type": "request",
      "name": "list-pages",
      "resource": "knowledge-base/pages",
      "method": "list",
      "integrated_account_id": "{{args.integrated_account_id}}"
    },
    {
      "type": "add_context",
      "name": "add-page-name",
      "depends_on": "list-pages",
      "config": {
        "expression": "{ \"page_id\": resources.`knowledge-base`.pages.id, \"page_title\": resources.`knowledge-base`.pages.title ? resources.`knowledge-base`.pages.title : \"Untitled_\" & resources.`knowledge-base`.pages.id, \"page_url\": resources.`knowledge-base`.pages.urls[type=\"view\"].url }"
      }
    },
    {
      "type": "request",
      "name": "get-page-content",
      "resource": "knowledge-base/page-content",
      "method": "list",
      "depends_on": "list-pages",
      "query": {
        "page": {
          "id": "{{resources.knowledge-base.pages.id}}"
        }
      },
      "recurse": {
        "if": "{{resources.knowledge-base.page-content.has_children:bool}}",
        "config": {
          "query": {
            "page_content_id": "{{resources.knowledge-base.page-content.id}}"
          }
        }
      },
      "integrated_account_id": "{{args.integrated_account_id}}"
    },
    {
      "name": "remove-remote-data",
      "type": "transform",
      "config": {
        "expression": "resources.`knowledge-base`.`page-content`.$sift(function($v, $k) { $k != remote_data })"
      },
      "depends_on": "get-page-content"
    },
    {
      "name": "all-page-content",
      "type": "spool",
      "depends_on": "remove-remote-data"
    },
    {
      "name": "combine-page-content",
      "type": "transform",
      "config": {
        "expression": "{ \"file_id\": page_id, \"file_name\": page_title, \"content\": $reduce($sortNodes(resources.`knowledge-base`.`page-content`, \"id\", \"parent.id\"), function($acc, $v) { $acc & $v.body.content }, \"\" ) }"
      },
      "depends_on": "all-page-content"
    },
    {
      "name": "google-cloud-storage",
      "type": "destination",
      "destination_type": "datastore",
      "method": "uploadObject",
      "config": {
        "id": "{{args.google_cloud_storage_datastore_id}}",
        "config": {
          "path": "teams/{{args.team_id}}/bots/{{args.bot_id}}/sources/{{args.source_id}}",
          "file_name": "{{page_title}}.md",
          "content": "{{payload.records.0.content}}",
          "upload_type": "resumable",
          "headers": {
            "Content-Type": "text/markdown",
            "X-Goog-Meta-File-Id": "{{page_id}}",
            "X-Goog-Meta-File-Url": "{{page_url}}"
          }
        }
      },
      "run_if": "$exists(args.google_cloud_storage_datastore_id)",
      "resources_to_persist": [
        "combine-page-content"
      ]
    }
  ],
  "environment_id": "5e6c1566-bd23-4b05-a481-f579eec913b7",
  "created_at": "2025-02-04T06:22:50.000Z",
  "updated_at": "2025-02-05T18:04:59.000Z",
  "default_runtime_version": 4,
  "label": "Fetch all the pages from Notion",
  "args_validation": "$firstNonEmpty(args.webhook_id) ? null : { \"message\": \"Need one of webhook_id or google_cloud_storage_datastore_id in args\" }"
}

{
  "display_information": {
    "name": "DocsBot",
    "description": "Instant AI answers from your documentation and content",
    "background_color": "#111827",
    "long_description": "Connect your DocsBot account to Slack and bring your AI Agents right into your workspace. Instantly answer questions, surface documentation, and support your team-without ever leaving Slack."
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "DocsBot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/docsbot",
        "url": "https://api.docsbot.ai/slack/events",
        "description": "Choose which DocsBot to talk to",
        "usage_hint": "[use|switch|clear] [bot name]",
        "should_escape": false
      }
    ],
    "assistant_view": {
      "assistant_description": "Your AI assistant for instant answers from your documentation and content.",
      "suggested_prompts": []
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://docsbot.ai/api/teams/"
    ],
    "scopes": {
      "user": [
        "users:read",
        "users:read.email"
      ],
      "bot": [
        "reactions:write",
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:join",
        "chat:write",
        "commands",
        "groups:history",
        "im:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://api.docsbot.ai/slack/events",
      "bot_events": [
        "app_mention",
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://api.docsbot.ai/slack/events",
      "message_menu_options_url": "https://api.docsbot.ai/slack/events"
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        },
        {
            "source": "/(chat|ask|iframe)/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOWALL"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/cron/reingest?key=iuefhisue24182",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/updateCounts?key=aowidjaowd3721",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/carbon?key=efjlnczww7236912",
            "schedule": "* * * * *"
        },
        {
            "path": "/api/cron/crawler?key=efjl95hdjysgq26912",
            "schedule": "* * * * *"
        }
    ],
    "functions": {
        "api/bento-webhook": {
            "maxDuration": 90
        },
        "api/teams/[teamId]/bots/[botId]/export-log": {
            "memory": 3008,
            "maxDuration": 300
        },
        "api/teams/[teamId]/bots/[botId]/stats": {
            "memory": 2048,
            "maxDuration": 120
        }
    }
}